    private JSONObject createCryptoToken(String reqDate, String reqNo) throws Exception {

        String accessToken = createAccessToken();

        JSONObject dataHeader = new JSONObject();
        dataHeader.put("lang_code", "kr");

        JSONObject dataBody = new JSONObject();
        dataBody.put("client_id", CLIENT_ID);
        dataBody.put("req_date", reqDate);
        dataBody.put("req_no", reqNo);
        dataBody.put("enc_mode", "1");

        JSONObject requestJson = new JSONObject();
        requestJson.put("dataHeader", dataHeader);
        requestJson.put("dataBody", dataBody);

        Map<String, String> headers = new HashMap<String, String>();
        headers.put("Content-Type", "application/json; charset=utf-8");
        headers.put("Accept", "application/json");
        headers.put("Authorization", "Bearer " + accessToken);

        String response = postJson(
                CREATE_TOKEN_URL,
                headers,
                requestJson.toJSONString()
        );

        System.out.println("CryptoToken response = " + response);

        JSONParser parser = new JSONParser();
        JSONObject responseJson = (JSONObject) parser.parse(response);
        JSONObject responseBody = (JSONObject) responseJson.get("dataBody");

        if (responseBody == null) {
            throw new IllegalStateException("Crypto Token 응답에 dataBody가 없습니다. response=" + response);
        }

        return responseBody;
    }
    

    private String callStos(
            String cryptoTokenId,
            String reqInfoEnc,
            String integrityValue
    ) throws Exception {

        JSONObject dataHeader = new JSONObject();
        dataHeader.put("CNTY_CD", "kr");
        dataHeader.put("TRAN_ID", TRAN_ID);

        JSONObject dataBody = new JSONObject();
        dataBody.put("crypto_token_id", cryptoTokenId);
        dataBody.put("reqInfo", reqInfoEnc);
        dataBody.put("integrity_value", integrityValue);

        JSONObject requestJson = new JSONObject();
        requestJson.put("dataHeader", dataHeader);
        requestJson.put("dataBody", dataBody);

        Map<String, String> headers = new HashMap<String, String>();
        headers.put("Content-Type", "application/json; charset=utf-8");

        return postJson(STOS_URL, headers, requestJson.toJSONString());
    }

    private String postJson(
            String urlStr,
            Map<String, String> headers,
            String body
    ) throws Exception {

        HttpURLConnection conn = null;

        try {
            URL url = new URL(urlStr);
            conn = (HttpURLConnection) url.openConnection();

            conn.setRequestMethod("POST");
            conn.setDoInput(true);
            conn.setDoOutput(true);
            conn.setConnectTimeout(5000);
            conn.setReadTimeout(10000);

            for (Map.Entry<String, String> entry : headers.entrySet()) {
                conn.setRequestProperty(entry.getKey(), entry.getValue());
            }

            BufferedWriter bw = null;
            try {
                bw = new BufferedWriter(
                        new OutputStreamWriter(conn.getOutputStream(), "UTF-8")
                );
                bw.write(body);
                bw.flush();
            } finally {
                if (bw != null) {
                    bw.close();
                }
            }

            InputStream is;

            if (conn.getResponseCode() >= 400) {
                is = conn.getErrorStream();
            } else {
                is = conn.getInputStream();
            }

            StringBuilder sb = new StringBuilder();

            BufferedReader br = null;
            try {
                br = new BufferedReader(new InputStreamReader(is, "UTF-8"));

                String line;
                while ((line = br.readLine()) != null) {
                    sb.append(line);
                }
            } finally {
                if (br != null) {
                    br.close();
                }
            }

            return sb.toString();

        } finally {
            if (conn != null) {
                conn.disconnect();
            }
        }
    }

    private String createSymmetricKey(
            String reqDate,
            String reqNo,
            String tokenVal
    ) throws Exception {

        String value = trim(reqDate) + trim(reqNo) + trim(tokenVal);

        MessageDigest md = MessageDigest.getInstance("SHA-256");
        byte[] digest = md.digest(value.getBytes("UTF-8"));

        return Base64.getEncoder().encodeToString(digest);
    }

    private String encryptAes(
            String key,
            String iv,
            String plainText
    ) throws Exception {

        SecretKeySpec secureKey =
                new SecretKeySpec(key.getBytes("UTF-8"), "AES");

        Cipher cipher = Cipher.getInstance("AES/CBC/PKCS5Padding");
        cipher.init(
                Cipher.ENCRYPT_MODE,
                secureKey,
                new IvParameterSpec(iv.getBytes("UTF-8"))
        );

        byte[] encrypted = cipher.doFinal(plainText.getBytes("UTF-8"));

        return Base64.getEncoder().encodeToString(encrypted);
    }

    private String decryptAes(
            String key,
            String iv,
            String encText
    ) throws Exception {

        SecretKeySpec secureKey =
                new SecretKeySpec(key.getBytes("UTF-8"), "AES");

        Cipher cipher = Cipher.getInstance("AES/CBC/PKCS5Padding");
        cipher.init(
                Cipher.DECRYPT_MODE,
                secureKey,
                new IvParameterSpec(iv.getBytes("UTF-8"))
        );

        byte[] decoded = Base64.getDecoder().decode(encText);
        byte[] decrypted = cipher.doFinal(decoded);

        return new String(decrypted, "UTF-8");
    }

    private String hmacSha256Base64(
            String hmacKey,
            String message
    ) throws Exception {

        Mac mac = Mac.getInstance("HmacSHA256");

        SecretKeySpec keySpec =
                new SecretKeySpec(hmacKey.getBytes("UTF-8"), "HmacSHA256");

        mac.init(keySpec);

        byte[] hmac = mac.doFinal(message.getBytes("UTF-8"));

        return Base64.getEncoder().encodeToString(hmac);
    }

    private String sha256Base64(String value) throws Exception {
        MessageDigest md = MessageDigest.getInstance("SHA-256");
        byte[] digest = md.digest(value.getBytes("UTF-8"));

        return Base64.getEncoder().encodeToString(digest);
    }

    public String now() {
        return new SimpleDateFormat("yyyyMMddHHmmss").format(new Date());
    }

    public String makeReqNum() {
        String time = now();
        int random = (int) (Math.random() * 900000) + 100000;

        return time + random;
    }

    private String trim(String value) {
        return value == null ? "" : value.trim();
    }

    private String stringValue(Object value) {
        return value == null ? null : String.valueOf(value);
    }

    public PccRequestResult createRequest(
            String id,
            String srvNo,
            String reqNum,
            String retUrl,
            String certDate,
            String certGb
    ) throws Exception {

        String reqDate = now();

        JSONObject tokenBody = createCryptoToken(reqDate, reqNum);

        String cryptoTokenId = stringValue(tokenBody.get("crypto_token_id"));
        String cryptoToken = stringValue(tokenBody.get("crypto_token"));

        String symmetricKey = createSymmetricKey(reqDate, reqNum, cryptoToken);

        String key = symmetricKey.substring(0, 16);
        String iv = symmetricKey.substring(symmetricKey.length() - 16);

        JSONObject reqJson = new JSONObject();
        reqJson.put("id", id);
        reqJson.put("srvNo", srvNo);
        reqJson.put("reqNum", reqNum);
        reqJson.put("retUrl", retUrl);
        reqJson.put("certDate", certDate);
        reqJson.put("certGb", certGb);

        String reqInfoEnc = encryptAes(key, iv, reqJson.toJSONString());

        String hmacKey = symmetricKey.substring(0, 32);
        String integrityValue = hmacSha256Base64(hmacKey, reqInfoEnc);

        PccRequestResult result = new PccRequestResult();
        result.setCryptoTokenId(cryptoTokenId);
        result.setReqInfoEnc(reqInfoEnc);
        result.setIntegrityValue(integrityValue);
        result.setKey(key);
        result.setIv(iv);

        return result;
    }


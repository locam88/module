    private String createAccessToken() throws Exception {

        URL url = new URL(ACCESS_TOKEN_URL);
        HttpsURLConnection conn = (HttpsURLConnection) url.openConnection();

        conn.setRequestMethod("POST");
        conn.setDoOutput(true);
        conn.setConnectTimeout(10000);
        conn.setReadTimeout(10000);

        conn.setRequestProperty("Content-Type", "application/json; charset=UTF-8");
        conn.setRequestProperty("Accept", "application/json");

        String basicAuth = CLIENT_ID + ":" + CLIENT_SECRET;
        String encodedAuth = Base64.getEncoder()
                .encodeToString(basicAuth.getBytes(StandardCharsets.UTF_8));

        conn.setRequestProperty("Authorization", "Basic " + encodedAuth);

        String json =
                "{"
              + "\"dataHeader\":{\"lang_code\":\"kr\"},"
              + "\"dataBody\":{"
              + "\"scope\":\"default\","
              + "\"grant_type\":\"client_credentials\""
              + "}"
              + "}";

        try (OutputStream os = conn.getOutputStream()) {
            os.write(json.getBytes(StandardCharsets.UTF_8));
            os.flush();
        }

        int status = conn.getResponseCode();

        InputStream is = status >= 200 && status < 300
                ? conn.getInputStream()
                : conn.getErrorStream();

        BufferedReader br = new BufferedReader(
                new InputStreamReader(is, StandardCharsets.UTF_8)
        );

        StringBuilder sb = new StringBuilder();
        String line;

        while ((line = br.readLine()) != null) {
            sb.append(line);
        }

        String response = sb.toString();

        System.out.println("AccessToken status = " + status);
        System.out.println("AccessToken response = " + response);

        if (status < 200 || status >= 300) {
            throw new IllegalStateException("AccessToken 발급 실패. response=" + response);
        }

        JSONParser parser = new JSONParser();
        JSONObject responseJson = (JSONObject) parser.parse(response);
        JSONObject dataBody = (JSONObject) responseJson.get("dataBody");

        if (dataBody == null) {
            throw new IllegalStateException("AccessToken 응답에 dataBody가 없습니다. response=" + response);
        }

        String accessToken = stringValue(dataBody.get("access_token"));

        if (accessToken == null || accessToken.trim().isEmpty()) {
            throw new IllegalStateException("AccessToken 응답에 access_token이 없습니다. response=" + response);
        }

        return accessToken;
    }
